{
  "version": "2.0.0",
  "tasks": [
    // ── Sync only (no server) ───────────────────────────────────────────────
    {
      "label": "Hugo: Sync content",
      "detail": "Run the sync script",
      "type": "shell",
      "command": "python .github/scripts/sync_content.py",
      "options": {
        "shell": {
          "executable": "wsl",
          "args": ["-d", "ArchDaemon"]
        }
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    // ─── Serve ────────────────────────────────────────────────────────────────
    {
      "label": "Hugo: Serve",
      "type": "shell",
      "command": "hugo server --buildDrafts --buildFuture --disableFastRender",
      "options": {
        "cwd": "${workspaceFolder}/site",
        "shell": {
          "executable": "wsl",
          "args": ["-d", "ArchDaemon"]
        }
      },
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(ERROR|WARN)(.*)$",
          "message": 2
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^(Building|Start building)",
          "endsPattern": "^Web Server is available"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },

    // ───Sync & Serve ──────────────────────────────────────────────────────────
    
    {
      "label": "Hugo: Sync and Serve",
      "dependsOn": ["Hugo: Sync content", "Hugo: Serve"]
    },

    // ─── New Post ─────────────────────────────────────────────────────────────
    {
      "label": "Hugo: Add New Post",
      "type": "shell",
      // Prompts for a slug, then creates content/posts/<slug>.md
      "command": "hugo new content/posts/${input:postSlug}.md",
      "options": {
        "cwd": "${workspaceFolder}/site",
        "shell": {
          "executable": "wsl",
          "args": ["-d", "ArchDaemon"]
        }
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },

    // ─── New Page (top-level) ─────────────────────────────────────────────────
    {
      "label": "Hugo: Add New Page",
      "type": "shell",
      "command": "hugo new content/${input:pagePath}.md",
      "options": {
        "cwd": "${workspaceFolder}/site",
        "shell": {
          "executable": "wsl",
          "args": ["-d", "ArchDaemon"]
        }
      },
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      }
    },

    // ─── Build ────────────────────────────────────────────────────────────────
    {
      "label": "Hugo: Build (production)",
      "type": "shell",
      "command": "hugo --minify",
      "options": {
        "cwd": "${workspaceFolder}/site",
        "shell": {
          "executable": "wsl",
          "args": ["-d", "ArchDaemon"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ],

  "inputs": [
    {
      "id": "postSlug",
      "type": "promptString",
      "description": "Post filename (slug) — e.g. my-new-post",
      "default": "my-new-post"
    },
    {
      "id": "pagePath",
      "type": "promptString",
      "description": "Page path inside content/ — e.g. about or projects/my-project",
      "default": "new-page"
    }
  ]
}
